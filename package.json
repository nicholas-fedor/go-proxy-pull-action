{
  "name": "go-proxy-pull-action",
  "version": "1.4.0",
  "description": "GitHub Action to pull the new release of a module to the Go proxy cache.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "bun build src/main.ts --bundle --outfile=dist/index.js --target=node",
    "commitlint": "commitlint",
    "prepare": "bun run build",
    "test": "bun test",
    "test:coverage": "bun test --coverage"
  },
  "keywords": [
    "github-action",
    "go-proxy-pull-action",
    "workflow",
    "go",
    "proxy",
    "cache"
  ],
  "author": "Nicholas Fedor",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.1.1",
    "@actions/tool-cache": "^4.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.8",
    "@semantic-release/release-notes-generator": "14.1.1",
    "@types/bun": "1.3.14",
    "@types/node": "25.9.2",
    "semantic-release": "25.0.3"
  },
  "overrides": {
    "undici": "^8.0.0"
  }
}
