{
  "repositoryUrl": "https://github.com/nicholas-fedor/go-proxy-pull-action",
  "branches": ["master"],
  "plugins": [
    {
      "path": "@semantic-release/commit-analyzer",
      "releaseRules": [
        { "type": "chore", "release": "patch" }
      ]
    },
    "@semantic-release/release-notes-generator",
    "@semantic-release/github"
  ]
}
